<?xml version="1.0" encoding="utf-8"?><!--
   Controls what's eligible for Android's cloud backup and device-to-device transfer.
   See https://developer.android.com/about/versions/12/backup-restore#xml-changes

   Excluded here: the Room database (contacts — including stored PGP public keys, notes, and
   custom fields — and the cached email list) and the push_state DataStore file (holds the
   UnifiedPush WebPush `auth` secret plus recent push notification previews). Both are local
   caches of data that already lives on the mail server, so nothing is lost by not backing them
   up, and it keeps that data out of Google's cloud backup and out of `adb backup` dumps.

   Left included (and therefore backed up): app preferences (theme, keyword visibility, pairing
   flag) and the other DataStore files (contacts_state, mail_sync_state — just sync cursors/
   watermarks, not user data), and SecurePairingStore's EncryptedSharedPreferences file — its
   AES key lives in Android Keystore and doesn't survive a restore onto different key material
   anyway, so backing up the ciphertext is harmless.
-->
<data-extraction-rules>
    <cloud-backup>
        <exclude domain="database" path="."/>
        <exclude domain="file" path="datastore/push_state.preferences_pb"/>
    </cloud-backup>
    <device-transfer>
        <exclude domain="database" path="."/>
        <exclude domain="file" path="datastore/push_state.preferences_pb"/>
    </device-transfer>
</data-extraction-rules>
